generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id                   String           @id @default(uuid()) @db.Uuid
  username             String           @unique
  email                String           @unique
  password             String
  role                 Role
  phonenumber          String?
  address              String?
  alternatePhonenumber String?          @map("alternate_phonenumber")
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  auth                 authorizations[]
  projects             projects[]
  refreshTokens        refreshTokens[]

  @@index([id, createdAt])
}

model refreshTokens {
  id       String  @id @default(uuid()) @db.Uuid
  familyId String  @map("family_id") @db.Uuid
  userId   String  @map("user_id") @db.Uuid
  role     Role    @default(INTERIOR)
  isUsed   Boolean @map("is_used")
  user     users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@map("refresh_tokens")
}

model customers {
  id                   String     @id @default(uuid()) @db.Uuid
  name                 String     @unique
  email                String?
  phonenumber          String?
  alternatePhonenumber String?    @map("alternate_phonenumber")
  address              String?
  createdAt            DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  orders               orders[]
  payments             payments[]
  projects             projects[]

  @@index([id, createdAt])
}

model brands {
  id              String            @id @default(uuid()) @db.Uuid
  name            String            @unique
  description     String?
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  catalogues      catalogues[]
  order           orders[]
  projectProducts projectProducts[]

  @@index([id, createdAt])
}

model catalogues {
  id              String            @id @default(uuid()) @db.Uuid
  brandId         String            @map("brand_id") @db.Uuid
  name            String            @unique
  type            String?
  price           Decimal?
  launchYear      String?           @map("launch_year")
  rackNo          Int?              @map("rack_no")
  description     String?
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  brand           brands            @relation(fields: [brandId], references: [id])
  order             orders[]
  projectProducts   projectProducts[]
  cataloguesGivenTo cataloguesGivenTo[]

  @@index([id, createdAt])
}

model DealsIn {
  id      String    @id @default(uuid()) @db.Uuid
  name    String    @unique
  dealers dealers[]

  @@map("deals_in")
}

model dealers {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  description   String?
  dealsInId     String   @map("deals_in_id") @db.Uuid
  personName    String   @map("person_name")
  phonenumber   String?
  email         String?
  catalogueLink String?  @map("catalogue_link")
  address       String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  DealsIn       DealsIn  @relation(fields: [dealsInId], references: [id], onDelete: Cascade)

  @@unique([name, personName])
}

model products {
  id              String             @id @default(uuid()) @db.Uuid
  name            String             @unique
  description     String?
  sellingUnit     SellingUnit?       @map("selling_unit")
  productType     String?            @map("product_type")
  price           Decimal?
  taxRate         Decimal?           @map("tax_rate")
  dimensionType   DimensionType?     @map("dimension_type")
  size            Decimal?
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  productCategory ProductCategory?   @map("product_category")
  measurmentsData measurementsData[]
  order           orders[]
  projectLabours  projectLabours[]
  projectProducts projectProducts[]

  @@index([id, createdAt])
}

model ArtisanTypes {
  id       String     @id @default(uuid()) @db.Uuid
  name     String     @unique
  artisans artisans[]

  @@map("artisan_types")
}

model artisans {
  id             String           @id @default(uuid()) @db.Uuid
  artisanTypeId  String           @map("artisan_type_id") @db.Uuid
  name           String
  phonenumber    String?
  email          String?
  address        String?
  price          Decimal
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  artisanType    ArtisanTypes     @relation(fields: [artisanTypeId], references: [id], onDelete: Cascade)
  projectLabours projectLabours[]

  @@unique([name, email, phonenumber])
  @@index([id, createdAt])
}

model areas {
  id               String             @id @default(uuid()) @db.Uuid
  name             String             @unique
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  measurementsData measurementsData[]
  order            orders[]
  projectProducts  projectProducts[]

  @@index([id, createdAt])
}

model banks {
  id            String     @id @default(uuid()) @db.Uuid
  bankName      String     @map("bank_name")
  accountName   String?    @map("account_name")
  branch        String
  pincode       String
  accountNumber String     @map("account_number")
  ifscCode      String     @map("ifsc_code")
  accountType   BankTypes  @map("account_type")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  project       projects[]

  @@index([id, createdAt])
}

model projects {
  id                 String            @id @default(uuid()) @db.Uuid
  name               String            @unique 
  customerId         String?           @map("customer_id") @db.Uuid
  creatorId          String            @map("creator_id") @db.Uuid
  status             ProjectStatus
  totalAmount        Decimal?          @map("total_amount")
  totalTax           Decimal?          @map("total_tax")
  paid               Decimal?
  discount           Decimal?
  discountType       String?           @map("discount_type")
  projectDate        DateTime          @map("project_date") @db.Timestamptz(6)
  additionalRequests String?           @map("additional_requests")
  address            String?
  bankId             String?           @map("bank_id") @db.Uuid
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  order              orders[]
  payments           payments[]
  projectLabours     projectLabours[]
  projectProducts    projectProducts[]
  bank               banks?            @relation(fields: [bankId], references: [id])
  creator            users             @relation(fields: [creatorId], references: [id])
  customer           customers?        @relation(fields: [customerId], references: [id])
  tasks              tasks[]

  @@index([id, createdAt])
}

model projectProducts {
  id              String        @id @default(uuid()) @db.Uuid
  projectId       String        @map("project_id") @db.Uuid
  productId       String        @map("product_id") @db.Uuid
  areaId          String?       @map("area_id") @db.Uuid
  price           Decimal?
  quantity        Int?
  brandId         String?       @map("company_id") @db.Uuid
  catalogueId     String?       @map("catalogue_id") @db.Uuid
  designNo        Int?          @map("design_no")
  references      String?
  measurementUnit SellingUnit?  @default(METER) @map("measurement_unit")
  width           Decimal?
  height          Decimal?
  length          Decimal?
  status          ProductStatus @default(PENDING)
  remark          String?
  orderId         String?       @map("order_id")
  area            areas?        @relation(fields: [areaId], references: [id], onDelete: Cascade)
  catalogue       catalogues?   @relation(fields: [catalogueId], references: [id], onDelete: Cascade)
  brand           brands?       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  product         products      @relation(fields: [productId], references: [id], onDelete: Cascade)
  project         projects      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_products")
}

model projectLabours {
  id         String       @id @default(uuid()) @db.Uuid
  projectId  String       @map("project_id") @db.Uuid
  productId  String       @map("product_id") @db.Uuid
  artisanId  String?      @map("artisan_id") @db.Uuid
  price      Decimal
  unit       SellingUnit
  key        String
  quantity   Decimal
  status     LabourStatus @default(PENDING)
  workName   String?      @map("work_name")
  labourType LabourType   @default(STITCHING) @map("labour_type")
  artisan    artisans?    @relation(fields: [artisanId], references: [id])
  product    products     @relation(fields: [productId], references: [id], onDelete: Cascade)
  project    projects     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_labours")
}

model tasks {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?
  taskDate    DateTime @map("task_date") @db.Timestamptz(6)
  projectId   String   @map("project_id") @db.Uuid
  priority    Priority
  status      Status
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  project     projects @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([id, createdAt])
  @@unique([title, projectId])
}

model stores {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  address     String?
  phonenumber Int
  email       String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([id, createdAt])
}

model payments {
  id          String      @id @default(uuid()) @db.Uuid
  customerId  String?     @map("customer_id") @db.Uuid
  projectId   String?     @map("project_id") @db.Uuid
  amount      Decimal
  paymentMode String      @map("payment_mode")
  type        PaymentType
  remarks     String?
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  customer    customers?  @relation(fields: [customerId], references: [id])
  project     projects?   @relation(fields: [projectId], references: [id])

  @@index([createdAt, id])
  @@index([createdAt, amount])
}

model inquiries {
  id           String   @id @default(uuid()) @db.Uuid
  projectName  String   @map("project_name")
  customerName String   @map("customer_name")
  phonenumber  String
  comments     String?
  createdAt    DateTime @default(now()) @map("inquiry_date") @db.Timestamptz(6)
  followUpDate DateTime @map("follow_up_date") @db.Timestamptz(6)

  @@unique([customerName, projectName])
}

model authorizations {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  access String
  user   users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, access])
}

model orders {
  id           String      @id @default(uuid()) @db.Uuid
  customerId   String      @map("customer_id") @db.Uuid
  orderedDate  DateTime?   @db.Timestamptz(6)
  quantity     Decimal?
  orderId      String?     @map("order_id")
  receivedDate DateTime?   @map("received_date") @db.Timestamptz(6)
  areaId       String?     @map("area_id") @db.Uuid
  brandId      String?     @map("brand_id") @db.Uuid
  catalogueId  String?     @map("catalogue_id") @db.Uuid
  productId    String      @map("product_id") @db.Uuid
  projectId    String      @map("project_id") @db.Uuid
  designNo     Int?        @map("design_no")
  area         areas?      @relation(fields: [areaId], references: [id])
  brand        brands?     @relation(fields: [brandId], references: [id])
  catalogue    catalogues? @relation(fields: [catalogueId], references: [id])
  customer     customers   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product      products    @relation(fields: [productId], references: [id], onDelete: Cascade)
  project      projects    @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model measurements {
  id               String             @id @default(uuid()) @db.Uuid
  projectName      String             @map("project_name") @unique
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  measurementsData measurementsData[]

  @@index([id, createdAt])
}

model measurementsData {
  id            String       @id @default(uuid()) @db.Uuid
  areaId        String       @map("area_id") @db.Uuid
  productId     String       @map("product_id") @db.Uuid
  length        Decimal?
  width         Decimal?
  height        Decimal?
  unit          SellingUnit? @default(METER)
  measurementId String       @map("measurement_id") @db.Uuid
  area          areas        @relation(fields: [areaId], references: [id])
  measurements  measurements @relation(fields: [measurementId], references: [id])
  product       products     @relation(fields: [productId], references: [id])

  @@map("measurements_data")
}

enum Role {
  USER
  ADMIN
  INTERIOR
  SALES_ASSOCIATE
}

enum SellingUnit {
  METER
  FEET
  INCHES
  CENTIMETER
  PANHA
  RFT
  SQFT
  SQM
  SQY
  ROLL
  PIECE
  PANEL
}

enum ProductType {
  SOFA
  CHAIR
  OTTOMANS_PUFFY
  CURTAIN
  ROMAN_BLINDS
  CORIAN
  ORTHO_QUIRE_GAADI
  BEDBACK
  PILLOW_COVERS
  CUSTOM_WALLPAPERS
  WOODEN_FLOORING
  PVC_FLOORING
  CARPET
  RUBBER_GYM_FLOORING
  ROLLER_ZEBRA_VENETIAN_VERTICALBLINDS
  BLINDS
  BEDSHEET
  PILLOW
  MATTRESS_READY
  MATTRESS_PROTECTOR
  COMFORTERS
  DINING
  WALLPAPER_ROLL
  RUGS
}

enum ProductCategory {
  CUSTOM
  AREA
  READY
}

enum DimensionType {
  lw
  lh
  lwh
  l
}

enum BankTypes {
  SAVINGS
  CURRENT
  RECURRING
  SALARY
}

enum Status {
  TODO
  INPROGRESS
  COMPLETED
}

enum ProjectStatus {
  PENDING
  ACTIVE
  GOODS_PENDING
  GOODS_COMPLETE
  TAILOR_PENDING
  TAILOR_COMPLETE
  COMPLETED
  DEFAULTER
}

enum ProductStatus {
  PENDING
  ORDERED
  RECEIVED
  INSTOCK
}

enum LabourStatus {
  PENDING
  COMPLETED
  RECEIVED
}

enum LabourType {
  STITCHING
  FABRICATION
  FITTING
}

enum Priority {
  HIGH
  MODERATE
  LOW
}

enum PaymentType {
  CREDIT
  DEBIT
}

model cataloguesGivenTo {
  id             String      @id @default(uuid()) @db.Uuid
  givenDate      DateTime    @map("given_date") @db.Timestamptz(6)
  clientName     String      @map("client_name")
  siteName       String      @map("site_name")
  catalogueId    String      @map("catalogue_id") @db.Uuid
  receivedStatus Boolean     @default(false) @map("received_status")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  catalogue      catalogues  @relation(fields: [catalogueId], references: [id], onDelete: Cascade)

  @@index([id, createdAt])
  @@map("catalogues_given_to")
  @@unique([clientName, siteName, catalogueId])
}

